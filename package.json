{
  "name": "dynoscope",
  "productName": "DynoScope",
  "version": "1.0.6-beta.1",
  "description": "A full-featured DynamoDB database viewer and manager",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --config electron-builder.yml",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint ."
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "latest",
    "@aws-sdk/credential-providers": "latest",
    "@aws-sdk/lib-dynamodb": "latest",
    "@aws-sdk/shared-ini-file-loader": "3.374.0",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-table": "^8.21.0",
    "@tanstack/react-virtual": "^3.13.0",
    "lucide-react": "^0.470.0",
    "papaparse": "^5.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
